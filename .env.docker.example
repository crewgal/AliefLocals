# Application
APP_URL=https://alieflocals.example.com
APP_HTTP_PORT=8080
JWT_SECRET=replace-with-a-secure-random-string

# Database (connects to the bamlead-vps-db MariaDB container on the VPS)
MYSQL_HOST=bamlead-mariadb
MYSQL_PORT=3306
MYSQL_DATABASE=alieflocals
MYSQL_USER=alieflocals
MYSQL_PASSWORD=change-me
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=

# Docker network
DB_NETWORK_NAME=bamlead-vps-db_bamlead-network

# Frontend
VITE_API_URL=/api
